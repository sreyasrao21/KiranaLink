# PORT
PORT=5001

# Mongo URI
MONGODB_URI=your_mongodb_connection_string_here

# Razorpay keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Twilio credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
TWILIO_VOICE_NUMBER=your_twilio_voice_number_here
TWILIO_WHATSAPP_NUMBER=whatsapp:your_twilio_whatsapp_number_here

# AI Service Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Backend Config
BACKEND_URL=your_backend_public_url_here
FRONTEND_URL=http://localhost:5174
JWT_SECRET=your_jwt_secret_here

# Feature Flags
DEMO_MODE=false
ENABLE_INVOICE_SCHEDULER=false

# Phone Config
VOICE_AGENT_TARGET_PHONE=+91xxxxxxxxxx
